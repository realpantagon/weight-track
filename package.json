{
  "name": "weight-track",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:worker\" \"pnpm dev:frontend\"",
    "dev:frontend": "vite",
    "dev:worker": "wrangler dev --config wrangler.toml",
    "build": "tsc -b && vite build",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:worker": "wrangler deploy",
    "deploy:frontend": "vite build && wrangler pages deploy dist",
    "preview": "vite preview",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "hono": "^4.9.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250912.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "wrangler": "^4.37.1"
  },
  "packageManager": "pnpm@10.15.1"
}
